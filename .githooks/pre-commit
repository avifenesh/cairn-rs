#!/usr/bin/env bash
set -euo pipefail

echo "═══ pre-commit ═══"

echo "  fmt..."
if ! cargo fmt --all --check >/dev/null 2>&1; then
  echo "  ❌ cargo fmt failed. Run 'cargo fmt --all'"
  exit 1
fi
echo "  ✓ fmt"

echo "  clippy..."
if ! cargo clippy --workspace --all-targets -- -D warnings >/dev/null 2>&1; then
  echo "  ❌ clippy warnings."
  cargo clippy --workspace --all-targets -- -D warnings 2>&1 | grep "error" | head -5
  exit 1
fi
echo "  ✓ clippy"

# Only check UI if ui/ files are staged
if git diff --cached --name-only | grep -q "^ui/"; then
  echo "  tsc..."
  if ! (cd ui && npx tsc --noEmit) >/dev/null 2>&1; then
    echo "  ❌ TypeScript check failed."
    (cd ui && npx tsc --noEmit) 2>&1 | head -10
    exit 1
  fi
  echo "  ✓ tsc"
fi

echo "═══ ✓ commit ok ═══"
