#!/usr/bin/env bash
set -euo pipefail

echo "═══ pre-push gate ═══"

echo "  fmt..."
if ! cargo fmt --all --check >/dev/null 2>&1; then
  echo "  ❌ cargo fmt failed. Run 'cargo fmt --all' and recommit."
  exit 1
fi
echo "  ✓ fmt"

echo "  clippy..."
if ! cargo clippy --workspace -- -D warnings 2>/dev/null | tail -1 | grep -q "Finished"; then
  echo "  ❌ clippy warnings. Fix before pushing."
  cargo clippy --workspace -- -D warnings 2>&1 | grep "error" | head -5
  exit 1
fi
echo "  ✓ clippy"

echo "  rust tests..."
RUST_OUT=$(cargo test --workspace --quiet 2>&1)
if echo "$RUST_OUT" | grep -q "FAILED"; then
  echo "  ❌ rust tests failed."
  echo "$RUST_OUT" | grep "FAILED\|failures" | head -10
  exit 1
fi
echo "  ✓ rust tests"

echo "  tsc..."
if ! (cd ui && npx tsc --noEmit) >/dev/null 2>&1; then
  echo "  ❌ TypeScript check failed."
  (cd ui && npx tsc --noEmit) 2>&1 | head -10
  exit 1
fi
echo "  ✓ tsc"

echo "  ui build..."
if ! (cd ui && npm run build) >/dev/null 2>&1; then
  echo "  ❌ UI build failed."
  exit 1
fi
echo "  ✓ ui build"

echo "  vitest..."
if ! (cd ui && npx vitest run --reporter=dot) >/dev/null 2>&1; then
  echo "  ❌ Component tests failed."
  (cd ui && npx vitest run) 2>&1 | grep "FAIL" | head -5
  exit 1
fi
echo "  ✓ vitest"

echo "  playwright..."
if ! (cd ui && npx playwright test --reporter=dot) >/dev/null 2>&1; then
  echo "  ❌ Playwright failed."
  (cd ui && npx playwright test --reporter=list) 2>&1 | grep "✘" | head -5
  exit 1
fi
echo "  ✓ playwright"

echo "═══ ✅ all gates passed ═══"
