#!/usr/bin/env bash
set -euo pipefail

echo "═══ pre-push gate ═══"

# Rust tests — mirror CI shape:
#  - Workspace lib tests (cargo test --workspace --lib) run
#    unconditionally on the Fabric-only workspace.
#  - cairn-runtime + cairn-orchestrator integration tests run
#    unconditionally (pure Rust, no daemons).
#  - cairn-app integration tests spawn the real cairn-app binary on an
#    ephemeral port against a shared Valkey testcontainer — docker
#    required, gated the same way the fabric suite is.
#  - cairn-fabric integration suite runs against a testcontainers-
#    managed Valkey; docker required, skipped if the daemon is
#    unreachable so laptops without docker can still push.
echo "  rust lib tests..."
if ! output=$(cargo test --workspace --lib 2>&1); then
  echo "  ❌ rust lib tests failed."
  echo "$output" | grep "FAILED\|failures" | head -10
  exit 1
fi
echo "  ✓ rust lib tests"

echo "  rust integration tests (runtime + orchestrator)..."
if ! output=$(cargo test --tests -p cairn-runtime -p cairn-orchestrator 2>&1); then
  echo "  ❌ rust integration tests failed."
  echo "$output" | grep "FAILED\|failures" | head -10
  exit 1
fi
echo "  ✓ rust integration tests"

echo "  fabric + app http integration (testcontainers)..."
if docker info >/dev/null 2>&1; then
  if ! output=$(cargo test -p cairn-fabric --test integration 2>&1); then
    echo "  ❌ fabric integration tests failed."
    echo "$output" | grep "FAILED\|failures" | head -10
    exit 1
  fi
  # --features debug-endpoints activates the RFC-011 debug route so
  # test_rfc011_colocation can assert partition placement. Release
  # builds MUST NOT enable this feature; see SECURITY.md.
  if ! output=$(cargo test -p cairn-app --tests --features debug-endpoints 2>&1); then
    echo "  ❌ cairn-app http integration tests failed."
    echo "$output" | grep "FAILED\|failures" | head -10
    exit 1
  fi
  echo "  ✓ fabric + app http integration"
else
  echo "  ⊘ fabric + app http integration (skipped — docker daemon unreachable)"
fi

echo "  ui build..."
if ! (cd ui && npm run build) >/dev/null 2>&1; then
  echo "  ❌ UI build failed."
  exit 1
fi
echo "  ✓ ui build"

echo "  vitest..."
if ! (cd ui && npx vitest run) >/dev/null 2>&1; then
  echo "  ❌ Component tests failed."
  (cd ui && npx vitest run) 2>&1 | grep "FAIL" | head -5
  exit 1
fi
echo "  ✓ vitest"

echo "  playwright..."
if curl -sf http://localhost:3000/health >/dev/null 2>&1; then
  if ! (cd ui && npx playwright test --reporter=dot) >/dev/null 2>&1; then
    echo "  ❌ Playwright failed."
    (cd ui && npx playwright test --reporter=list) 2>&1 | grep "✘" | head -5
    exit 1
  fi
  echo "  ✓ playwright"
else
  echo "  ⊘ playwright (skipped — server not running on :3000)"
fi

echo "═══ ✅ all gates passed ═══"
