#!/usr/bin/env bash
set -euo pipefail

echo "═══ pre-push gate ═══"

# Rust tests — mirror CI shape:
#  - Workspace lib tests (cargo test --workspace --lib). Post in-memory-
#    runtime removal, every per-crate lib test runs unconditionally on
#    the Fabric-only workspace.
#  - cairn-app integration tests ride the FakeFabric read-only fixture
#    under `crates/cairn-app/tests/support/` — no Valkey required.
#  - cairn-fabric integration suite runs separately against a
#    testcontainers-managed Valkey (docker required; skipped if the
#    daemon is unreachable so laptops without docker can still push).
echo "  rust lib tests..."
if ! output=$(cargo test --workspace --lib 2>&1); then
  echo "  ❌ rust lib tests failed."
  echo "$output" | grep "FAILED\|failures" | head -10
  exit 1
fi
echo "  ✓ rust lib tests"

echo "  rust integration tests (runtime + orchestrator + app)..."
if ! output=$(cargo test --tests -p cairn-runtime -p cairn-orchestrator -p cairn-app 2>&1); then
  echo "  ❌ rust integration tests failed."
  echo "$output" | grep "FAILED\|failures" | head -10
  exit 1
fi
echo "  ✓ rust integration tests"

echo "  fabric integration (testcontainers)..."
if docker info >/dev/null 2>&1; then
  if ! output=$(cargo test -p cairn-fabric --test integration 2>&1); then
    echo "  ❌ fabric integration tests failed."
    echo "$output" | grep "FAILED\|failures" | head -10
    exit 1
  fi
  echo "  ✓ fabric integration"
else
  echo "  ⊘ fabric integration (skipped — docker daemon unreachable)"
fi

echo "  ui build..."
if ! (cd ui && npm run build) >/dev/null 2>&1; then
  echo "  ❌ UI build failed."
  exit 1
fi
echo "  ✓ ui build"

echo "  vitest..."
if ! (cd ui && npx vitest run) >/dev/null 2>&1; then
  echo "  ❌ Component tests failed."
  (cd ui && npx vitest run) 2>&1 | grep "FAIL" | head -5
  exit 1
fi
echo "  ✓ vitest"

echo "  playwright..."
if curl -sf http://localhost:3000/health >/dev/null 2>&1; then
  if ! (cd ui && npx playwright test --reporter=dot) >/dev/null 2>&1; then
    echo "  ❌ Playwright failed."
    (cd ui && npx playwright test --reporter=list) 2>&1 | grep "✘" | head -5
    exit 1
  fi
  echo "  ✓ playwright"
else
  echo "  ⊘ playwright (skipped — server not running on :3000)"
fi

echo "═══ ✅ all gates passed ═══"
