#!/usr/bin/env bash
set -euo pipefail

echo "═══ pre-push gate ═══"

# Rust tests — mirror CI shape:
#  - Workspace lib tests under `--features cairn-app/in-memory-runtime`.
#    The runtime / orchestrator / app test modules are gated on this
#    feature (PR #27); without it the binaries compile to zero tests
#    and the hook would ship blind. This is what CI's `test` job runs.
#  - cairn-fabric integration suite runs separately against a
#    testcontainers-managed Valkey (docker required; skipped if the
#    daemon is unreachable so laptops without docker can still push).
#    This is what CI's `fabric-integration` job runs.
echo "  rust lib tests (--features in-memory-runtime)..."
if ! cargo test --workspace --lib --features cairn-app/in-memory-runtime --quiet >/dev/null 2>&1; then
  echo "  ❌ rust lib tests failed."
  cargo test --workspace --lib --features cairn-app/in-memory-runtime 2>&1 | grep "FAILED\|failures" | head -10
  exit 1
fi
echo "  ✓ rust lib tests"

echo "  fabric integration (testcontainers)..."
if docker info >/dev/null 2>&1; then
  if ! cargo test -p cairn-fabric --test integration --quiet >/dev/null 2>&1; then
    echo "  ❌ fabric integration tests failed."
    cargo test -p cairn-fabric --test integration 2>&1 | grep "FAILED\|failures" | head -10
    exit 1
  fi
  echo "  ✓ fabric integration"
else
  echo "  ⊘ fabric integration (skipped — docker daemon unreachable)"
fi

echo "  ui build..."
if ! (cd ui && npm run build) >/dev/null 2>&1; then
  echo "  ❌ UI build failed."
  exit 1
fi
echo "  ✓ ui build"

echo "  vitest..."
if ! (cd ui && npx vitest run) >/dev/null 2>&1; then
  echo "  ❌ Component tests failed."
  (cd ui && npx vitest run) 2>&1 | grep "FAIL" | head -5
  exit 1
fi
echo "  ✓ vitest"

echo "  playwright..."
if curl -sf http://localhost:3000/health >/dev/null 2>&1; then
  if ! (cd ui && npx playwright test --reporter=dot) >/dev/null 2>&1; then
    echo "  ❌ Playwright failed."
    (cd ui && npx playwright test --reporter=list) 2>&1 | grep "✘" | head -5
    exit 1
  fi
  echo "  ✓ playwright"
else
  echo "  ⊘ playwright (skipped — server not running on :3000)"
fi

echo "═══ ✅ all gates passed ═══"
