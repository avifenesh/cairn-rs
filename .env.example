# Cairn environment configuration — copy to .env and fill in your values.
# Loaded automatically at startup. Never commit .env to version control.

CAIRN_ADMIN_TOKEN=change-me-in-production

# Connect your LLM provider (any OpenAI-compatible endpoint).
# Only set the vars for the provider you're using.

# OpenAI
# CAIRN_BRAIN_URL=https://api.openai.com/v1
# OPENAI_COMPAT_API_KEY=sk-...

# Anthropic (via OpenAI-compatible proxy)
# CAIRN_BRAIN_URL=https://your-anthropic-proxy/v1
# OPENAI_COMPAT_API_KEY=sk-ant-...

# OpenRouter (200+ models, free tier available)
# CAIRN_BRAIN_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_COMPAT_API_KEY=sk-or-v1-...

# Ollama (local)
# OLLAMA_HOST=http://localhost:11434

# AWS Bedrock / Google Vertex — configure via POST /v1/providers/connections

# Encryption key for credential storage (required in team mode)
# CAIRN_ENCRYPTION_KEY=your-256-bit-key-here
