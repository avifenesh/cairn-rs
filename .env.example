# Cairn — environment configuration
# Copy to .env and fill in your values. Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# Postgres (default, recommended for production):
# DATABASE_URL=postgres://cairn:cairn-dev-password@localhost:5432/cairn

# SQLite (single-node / edge):
# DATABASE_URL=sqlite:cairn.db

# In-memory (dev only — all data lost on restart):
# Use --db memory flag, no DATABASE_URL needed.

# Postgres password (used by docker-compose for the postgres service):
# POSTGRES_PASSWORD=cairn-dev-password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Admin bearer token — MUST change in production.
CAIRN_ADMIN_TOKEN=change-me-in-production

# Read token from a file (Docker secrets pattern, takes precedence over CAIRN_ADMIN_TOKEN):
# CAIRN_ADMIN_TOKEN_FILE=/run/secrets/cairn_admin_token

# Encryption key for credential storage at rest (required in team mode):
# CAIRN_ENCRYPTION_KEY=your-256-bit-base64-key-here

# ── Server ────────────────────────────────────────────────────────────────────
# Deployment mode: "local" (no auth required) or "team" (token required on every request).
# CAIRN_MODE=team

# Bind address and port:
# CAIRN_ADDR=0.0.0.0
# CAIRN_PORT=3000

# ── LLM Providers ────────────────────────────────────────────────────────────
# Cairn is provider-agnostic. Connect any OpenAI-compatible endpoint, or use
# native adapters for Bedrock, Vertex, Ollama, etc.
#
# You can also configure providers at runtime via the dashboard (Providers page)
# or POST /v1/providers/connections.

# Generic OpenAI-compatible (works with OpenAI, Anthropic proxies, Together, etc.):
# CAIRN_BRAIN_URL=https://api.openai.com/v1
# CAIRN_WORKER_URL=https://api.openai.com/v1
# OPENAI_COMPAT_API_KEY=sk-...
# OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1

# OpenRouter (200+ models):
# OPENROUTER_API_KEY=sk-or-v1-...

# Ollama (local inference):
# OLLAMA_HOST=http://localhost:11434

# AWS Bedrock:
# BEDROCK_API_KEY=your-bedrock-api-key
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# AWS_REGION=us-east-1

# Groq:
# CAIRN_BRAIN_URL=https://api.groq.com/openai/v1
# OPENAI_COMPAT_API_KEY=gsk_...

# DeepSeek:
# CAIRN_BRAIN_URL=https://api.deepseek.com/v1
# OPENAI_COMPAT_API_KEY=sk-...

# xAI (Grok):
# CAIRN_BRAIN_URL=https://api.x.ai/v1
# OPENAI_COMPAT_API_KEY=xai-...

# Google AI (Gemini via OpenAI-compatible):
# CAIRN_BRAIN_URL=https://generativelanguage.googleapis.com/v1beta/openai
# OPENAI_COMPAT_API_KEY=AIza...

# ── Logging ───────────────────────────────────────────────────────────────────
# Verbosity filter (default: info):
# RUST_LOG=cairn_app=info,tower_http=debug

# Directory for daily-rotating log files (disabled when unset):
# CAIRN_LOG_DIR=/var/log/cairn

# ── GitHub App Integration ───────────────────────────────────────────────────
# All three are required to enable webhook processing.
# GITHUB_APP_ID=123456
# GITHUB_PRIVATE_KEY_FILE=/path/to/private-key.pem
# GITHUB_WEBHOOK_SECRET=your-webhook-secret
