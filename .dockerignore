# ── Rust build artifacts ──────────────────────────────────────────────────────
# Largest directory by far; always rebuilt inside Docker.
target/

# ── Version control ───────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── UI build artifacts ────────────────────────────────────────────────────────
# node_modules is installed fresh inside the ui-builder stage.
ui/node_modules/
ui/.vite/
# Stale dist from host — always rebuilt by the ui-builder stage.
ui/dist/

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ── CI / local tooling ────────────────────────────────────────────────────────
.github/

# ── Agent coordination and memory logs ───────────────────────────────────────
.coordination/
.remember/

# ── Documentation / non-build files ──────────────────────────────────────────
*.md
docs/
scripts/
agent-knowledge/
tests/

# ── Test fixtures and coverage ────────────────────────────────────────────────
coverage/
lcov.info

# ── Local environment (may contain secrets) ───────────────────────────────────
.env
.env.*
*.local

# ── Docker files (avoid recursive COPY) ──────────────────────────────────────
Dockerfile
.dockerignore
docker-compose.yml
